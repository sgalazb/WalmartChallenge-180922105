            <stringProp name="script">import groovy.json.JsonSlurper //librería para que groovy manipule json
import groovy.json.JsonOutput //salida para que se arme el json
import java.util.concurrent.ThreadLocalRandom //generación de números aleatorios

def response = prev.getResponseDataAsString() //obtengo la respuesta de &quot;Get paginated Products&quot;
def json = new JsonSlurper().parseText(response) //se parsea para interpretar el json

def products = json.data.items.findAll {
    it.stock != null &amp;&amp; it.stock &gt; 0
} //busco todos los productos que tengan un stock sobre 0 y además no sean null

if (products.isEmpty()) {
    throw new IllegalStateException(&quot;No hay productos con stock disponible&quot;)
} //si, el json responde vacío, se respond e este error

def maxProducts = Math.min(3, products.size()) //se prepara un random de 1 a 5 para poder capturar x productos
def numberOfProducts = ThreadLocalRandom.current().nextInt(1, maxProducts + 1) //obtiene los productos

Collections.shuffle(products) //se mezclan los productos para que no se repitan


def selectedProducts = products.take(numberOfProducts) //selecciono los productos

def items = []

selectedProducts.each { product -&gt;

    def stock = product.stock as int
    def maxQuantity = Math.min(stock, 5)
    def quantity = ThreadLocalRandom.current().nextInt(1, maxQuantity + 1)

    items.add([
        sku: product.sku,
        quantity: quantity
    ])
} //genero el stock, la candidad de forma aleatoria en un rango que sea válido y preparo los valores para el json


def userEmail = vars.get(&quot;userEmail&quot;)


def orderJson = JsonOutput.toJson([
    items: items,
    userEmail: userEmail
]) //se arma el json


vars.put(&quot;orderItems&quot;, orderJson) //se genera la variable con el json construido

log.info(&quot;Order generada: &quot; + orderJson) //logs para reporte.</stringProp>
